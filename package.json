{
  "name": "elchika-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Elchika tool applications",
  "scripts": {
    "build": "vp build",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "create-app": "node scripts/create-app.js",
    "delete-app": "node scripts/delete-app.js",
    "storybook": "storybook dev -p 6006 --config-dir .storybook",
    "build-storybook": "storybook build --config-dir .storybook",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "test:coverage": "vp test --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:all": "vp test && playwright test"
  },
  "keywords": [
    "monorepo",
    "cloudflare-workers",
    "cloudflare-pages",
    "tools"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@iarna/toml": "^2.2.5",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@typescript/native-preview": "^7.0.0-dev.20251113.1",
    "@voidzero-dev/vite-plus-test": "^0.1.12",
    "canvas": "^3.2.0",
    "happy-dom": "^20.0.10",
    "playwright": "^1.56.1",
    "storybook": "^10.2.19",
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.12",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.12",
    "wrangler": "^4.0.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}